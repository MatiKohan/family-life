generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(cuid())
  googleId         String?        @unique
  email            String         @unique
  name             String
  avatarUrl        String?
  password         String?
  refreshTokenHash String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  families         FamilyMember[]
  pushSubscriptions PushSubscription[]
  activityLogs     ActivityLog[]
}

model Family {
  id        String          @id @default(cuid())
  name      String
  emoji     String          @default("🏠")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  members   FamilyMember[]
  invites   FamilyInvite[]
  events    CalendarEvent[]
  pages        Page[]
  folders      PageFolder[]
  activityLogs ActivityLog[]
}

model PageFolder {
  id        String   @id @default(cuid())
  familyId  String
  name      String
  emoji     String   @default("📁")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  pages     Page[]
  activityLogs ActivityLog[]
}

model Page {
  id                String      @id @default(cuid())
  familyId          String
  title             String
  emoji             String      @default("📄")
  type              String
  sortOrder         Int         @default(0)
  folderId          String?
  items             Json        @default("[]")
  taskItems         Json        @default("[]")
  eventIds          Json        @default("[]")
  metadata          Json        @default("{}")
  apartmentListings Json        @default("[]")
  lastSyncedAt      DateTime?
  createdBy         String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  deletedAt         DateTime?
  family            Family      @relation(fields: [familyId], references: [id], onDelete: Cascade)
  folder            PageFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
}

model CalendarEvent {
  id                   String    @id @default(cuid())
  familyId             String
  title                String
  description          String?
  startAt              DateTime
  endAt                DateTime
  isAllDay             Boolean   @default(false)
  reminderMinutesBefore Int?
  reminderSentAt       DateTime?
  createdBy            String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  family               Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model FamilyMember {
  id                   String     @id @default(cuid())
  familyId             String
  userId               String
  role                 FamilyRole @default(MEMBER)
  whatsappPhone        String?
  notificationSettings Json       @default("{}")
  joinedAt             DateTime   @default(now())
  family               Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
}

model FamilyInvite {
  id        String       @id @default(cuid())
  familyId  String
  token     String       @unique @default(cuid())
  email     String?
  phone     String?
  status    InviteStatus @default(PENDING)
  expiresAt DateTime
  createdBy String
  createdAt DateTime     @default(now())
  family    Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

enum FamilyRole {
  OWNER
  ADMIN
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  familyId  String
  userId    String
  type      String
  payload   Json     @default("{}")
  createdAt DateTime @default(now())
  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId, createdAt(sort: Desc)])
}

model NotificationLog {
  id        String   @id @default(cuid())
  type      String   // 'invite' | 'assignment' | 'reminder'
  channel   String   // 'whatsapp'
  to        String   // phone number
  status    String   // 'sent' | 'failed'
  error     String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  familyId  String
  userId    String
  type      String
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  family    Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId, createdAt(sort: Desc)])
}
